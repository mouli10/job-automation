# Environment Configuration for AI Job Automation System

# LLM Providers (Add whichever you plan to use)
GEMINI_API_KEY="your_gemini_api_key_here"
OPENAI_API_KEY="your_openai_api_key_here"

# Default Model Config
LLM_PROVIDER="gemini" # or "openai"

# Email Configuration
GMAIL_USER="your.email@gmail.com"
GMAIL_PASSWORD="your_app_password_here"

# Scraper Configuration
SEARCH_ROLES="Data Analyst, Data Engineer, Business Analyst"
SEARCH_LOCATIONS="Remote, New York, San Francisco"

# Scraping Engine: "linkedin_cookie" or "apify"
SCRAPER_ENGINE="linkedin_cookie"

# 1. For linkedin_cookie engine:
LINKEDIN_LI_AT_COOKIE="your_li_at_cookie_value_here"

# 2. For apify engine (Future):
APIFY_API_TOKEN="your_apify_api_token"

# Scraping Safety & Schedule Limits
SCRAPER_MIN_DELAY=3
SCRAPER_MAX_DELAY=8
SCRAPER_MAX_PAGES=5
SCRAPER_MAX_JOBS_DAY=150
SCHEDULE_TIME="07:00"

# Database Configuration
# Using local SQLite by default
DATABASE_URL="sqlite:///./data/jobs.db"
